###################
#     Aliases         #
###################
alias co='git checkout'
alias cob='git checkout -b'
alias com='git checkout master && git pull'
alias gpom='git pull origin master'
alias gs='git status'
alias gsp='git stash pop'
alias gt='git stash'
alias gu='git push'
alias t='tmux -2'
alias tmux='tmux -2'
alias v=vim
alias vp='vim ~/.vimrc'
alias sbp='source ~/.bashrc_personal'
alias gdom='git diff origin/master'
alias react='cd ~/repos/archon/packages/archon-react'
alias api='cs ~/repos/archon/packages/archon-api'
alias sb='source ~/.bash_profile'
alias bp='vim ~/.bash_profile'
alias zp='vim ~/.zshrc'

